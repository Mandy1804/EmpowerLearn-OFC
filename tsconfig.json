{
  "extends": "@tsconfig/recommended/tsconfig.json",

  "compilerOptions": {
    "rootDir": "src", //pasta do cod typescript
    "outDir": "lib", // pasta de saida para os arquivos compilados
    "sourceMap": true, // cria um mapa quando ele transforma o cod ts para o js para facilitar o debug
    "noImplicitAny": true, // não permite variaveis ou parmetros sem tipo
    "noImplicitReturns": true, // verifica se todas funcoes tem tiro de retorno informado
    "noEmitOnError": true, // não gera o cod js se aparecer algum erro durante a compilacao 
    "strictNullChecks": true, // forca verificacao de valores null ou undefined, essa propiedade faz a verificacao se a gente n atribuir que ela é null ou undefd
    "noUnusedLocals": true // mostra quandos deixamos variavis decladas porem sem uso, famoso "lixo", da pra gerar o cod js se tiver assim
  },

  "compileOnSave": true, // toda vez que salvar o cod é para ele compilar
  "include": ["src/**/*"], // incluie a pasta src, todos os arquivos no src vao ser utilizados para transformar e compilar nosso cod
  "exclude": ["**/*.spec.ts"] // excluir todo arquivo de teste
}