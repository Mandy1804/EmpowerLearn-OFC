# ============================
# Servidor
# ============================
PORT=3000

# ============================
# Banco de dados (PostgreSQL)
# ============================
DATABASE_URL="postgresql://USUARIO:SENHA@localhost:5432/NOME_DO_BANCO"

# ============================
# Redis (cache)
# ============================
REDIS_URL="redis://localhost:6379"

# ============================
# RabbitMQ (mensageria)
# ============================
RABBITMQ_URL="amqp://USUARIO:SENHA@localhost:5672"

# ============================
# JWT (autenticacao)
# ============================
JWT_SECRET=substitua_por_uma_string_aleatoria_longa
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=outra_string_aleatoria_longa_diferente
JWT_REFRESH_EXPIRES_IN=7d

# ============================
# Sessao (painel admin)
# ============================
SESSION_SECRET=outra_string_aleatoria_longa

# ============================
# IA (OpenRouter)
# ============================
OPENROUTER_API_KEY=